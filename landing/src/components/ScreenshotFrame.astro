---
// ScreenshotFrame — slate browser chrome wrapper for app screenshots. Enforces
// an aspect-ratio box so images reserve space and never cause layout shift
// (CLS). `alt` is required (resilience contract: alt describes the surface).
//
// Pass `image` (an astro:assets import) to flow the screenshot through the
// AVIF/WebP responsive pipeline (preferred). `src` (plain string) stays as a
// fallback for static public assets.
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image?: ImageMetadata; // astro:assets import — emits responsive srcset
  src?: string; // plain string fallback (e.g. /logo.png)
  alt: string; // required — describes the surface for the no-image fallback
  width?: number;
  height?: number;
  ratio?: string; // CSS aspect-ratio, e.g. "16 / 10"
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "auto" | "low";
  widths?: number[]; // srcset widths (must not exceed source width)
  sizes?: string; // responsive sizes hint
}
const {
  image,
  src,
  alt,
  width,
  height,
  ratio = "16 / 10",
  loading = "lazy",
  fetchpriority = "auto",
  widths = [400, 800],
  sizes = "(max-width: 640px) 90vw, (max-width: 1024px) 70vw, 560px",
} = Astro.props;
---

<figure class="frame screenshot-frame">
  <div class="frame__chrome" aria-hidden="true">
    <span class="frame__dot"></span>
    <span class="frame__dot"></span>
    <span class="frame__dot"></span>
  </div>
  <div class="frame__viewport" style={`aspect-ratio: ${ratio};`}>
    {
      image ? (
        <Picture
          class="frame__img"
          src={image}
          alt={alt}
          formats={["avif", "webp"]}
          widths={widths}
          sizes={sizes}
          loading={loading}
          fetchpriority={fetchpriority}
          decoding="async"
        />
      ) : (
        <img
          class="frame__img"
          src={src}
          alt={alt}
          width={width}
          height={height}
          loading={loading}
          fetchpriority={fetchpriority}
          decoding="async"
        />
      )
    }
  </div>
</figure>

<style>
  .frame {
    margin: 0;
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-ink);
    border: 1px solid var(--color-ink);
    box-shadow: var(--shadow-card);
  }
  .frame__chrome {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-ink);
  }
  .frame__dot {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.22);
  }
  .frame__viewport {
    width: 100%;
    background: var(--color-bg-alt);
  }
  /* <Picture> wraps the <img> in a <picture> — make it fill the viewport box. */
  .frame__viewport :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .frame__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }
</style>
