---
// FeatureBlock — image + title + body. The `reverse` prop alternates the layout
// (image-left/right) on desktop; below 1024px it always stacks with the image
// above the text. Screenshots flow through ScreenshotFrame -> astro:assets and
// lazy-load (below the fold).
import type { ImageMetadata } from "astro";
import ScreenshotFrame from "./ScreenshotFrame.astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  title: string;
  ratio?: string;
  widths?: number[];
  reverse?: boolean;
}
const {
  image,
  alt,
  title,
  ratio = "16 / 10",
  widths = [400, 800],
  reverse = false,
} = Astro.props;
---

<div class:list={["feature", { "feature--reverse": reverse }]}>
  <div class="feature__media">
    <ScreenshotFrame
      image={image}
      alt={alt}
      ratio={ratio}
      widths={widths}
      loading="lazy"
      sizes="(max-width: 1024px) 92vw, 540px"
    />
  </div>
  <div class="feature__text">
    <h3 class="feature__title">{title}</h3>
    <p class="feature__body"><slot /></p>
  </div>
</div>

<style>
  .feature {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }
  .feature__title {
    font-size: var(--text-heading);
    line-height: var(--leading-heading);
  }
  .feature__body {
    margin-top: var(--space-md);
    max-width: 52ch;
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--color-muted);
  }

  /* Desktop: two columns, alternating image-left / image-right. */
  @media (min-width: 1024px) {
    .feature {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4xl);
    }
    .feature--reverse .feature__media {
      order: 2;
    }
  }
</style>
