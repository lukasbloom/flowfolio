# Copy to .env next to compose.yml and adjust before the first run.
# Every variable here is optional — a bare `docker compose up -d` works with an
# empty file. These are exactly the variables the single-image stack passes
# through; anything else in this file is ignored by that stack.

# Your public hostname, e.g. flowfolio.example.com. Set it to have Caddy obtain
# HTTPS automatically on ports 80/443 (Let's Encrypt) — the zero-extra-infra path.
# Leave empty for BOTH a local trial (http://localhost:8080) AND when you run
# behind your own reverse proxy that already terminates TLS: the app then serves
# plain HTTP on port 8080 for any hostname.
DOMAIN=

# Defaults to production: Swagger /api/docs disabled and the session cookie is
# marked Secure (HTTPS-only). Leave empty for any real deployment — direct HTTPS
# (DOMAIN set) or behind your own reverse proxy — and it hardens automatically,
# no value needed. Set to "development" ONLY for a plain-HTTP local trial, where
# a Secure cookie can't ride http://localhost (Chrome and Firefox tolerate it,
# Safari does not).
APP_ENV=

# Optional pre-seeded login password for headless/automated installs. Leave
# empty to choose the password in the first-run setup wizard (recommended).
# Must be 8+ characters, same floor as the interactive setup, boot refuses
# anything shorter.
APP_PASSWORD=

# Session-signing key. Leave empty and the app generates a strong random key on
# first boot and persists it in the data volume. Set it only if you manage
# secrets externally. Generate with: openssl rand -base64 32
SECRET_KEY=

# ── Backups ─────────────────────────────────────────────────────────────────
# rclone destination for encrypted off-host backups, e.g.
# "b2:my-bucket/flowfolio/" or "s3:my-bucket/flowfolio/". Leave empty to keep
# the nightly backups local-only (inside the backups volume).
BACKUP_DEST=

# Symmetric passphrase encrypting every backup artifact (age encryption).
# Generate with: openssl rand -base64 32
# WARNING: store it securely — losing it means backups cannot be decrypted.
BACKUP_ENCRYPTION_KEY=

# Days of daily backups to keep, locally and remotely.
BACKUP_RETAIN_DAYS=30

# ── Contributors (multi-container dev stack) ────────────────────────────────
# compose.multi.yml + compose.dev.yml read this same file, with two twists:
#   - SECRET_KEY is REQUIRED there (the api service refuses to start without it)
#   - the api container also loads this file directly, so APP_ENV/APP_PASSWORD
#     work the same way
# Pricing API keys (Finnhub, CoinGecko) are NOT environment variables in any
# stack — configure them in-app under Settings once logged in.
