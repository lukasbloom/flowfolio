# Copy to .env and fill in values before running
SECRET_KEY=generate-a-strong-random-value-here
DATABASE_URL=sqlite+aiosqlite:////data/flowfolio.db
LOG_LEVEL=WARNING

# Single-user auth — set a STRONG password (used by /api/auth/login).
# To rotate: change here and restart the api container.
APP_PASSWORD=changeme

# APP_ENV gates production-only behaviour:
# - production: Swagger /api/docs disabled; cookies sent secure (HTTPS-only)
# - development: Swagger enabled; cookies allow plain HTTP
APP_ENV=development

# Leave blank for now
FINNHUB_API_KEY=
COINGECKO_API_KEY=

# Backup configuration
# BACKUP_DEST: rclone destination, e.g. "b2:my-flowfolio-backups/" or "s3:my-bucket/flowfolio/"
BACKUP_DEST=
# BACKUP_ENCRYPTION_KEY: symmetric passphrase for age encryption
# Generate with: openssl rand -base64 32
# WARNING: store this securely — losing it means backups cannot be decrypted
BACKUP_ENCRYPTION_KEY=
# BACKUP_RETAIN_DAYS: number of daily backups to keep remotely (default: 30)
BACKUP_RETAIN_DAYS=30
