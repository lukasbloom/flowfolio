# Site address env-switches the deploy mode:
#   DOMAIN unset  -> :8080, plain HTTP on 8080 for ANY Host, NO cert attempt.
#                    Covers BOTH the local trial (http://localhost:8080) and the
#                    behind-a-reverse-proxy case: your proxy terminates TLS and
#                    forwards whatever Host it likes, and a port-only site address
#                    matches every Host (a host-locked `localhost` block would
#                    answer proxied requests with an empty 200). The session
#                    cookie is Secure by default (APP_ENV defaults to production).
#   DOMAIN=host   -> Caddy runs ACME automatic HTTPS on 443 for that hostname
#                    (the zero-extra-infra path: expose 80/443, get HTTPS).
# The no-DOMAIN case stays plain HTTP — no self-signed cert directive — because
# an internal-CA cert is untrusted and breaks plain-HTTP localhost.
#
# ACME defaults to Let's Encrypt production. For first-boot domain testing
# against the LE staging CA, uncomment the global block below and set ACME_CA
# (an empty acme_ca value fails Caddyfile validation, so it can't be gated by
# an unset env var inline — keep it commented until staging is actually needed):
#   {
#       acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
#   }

{$DOMAIN::8080} {
    # Security headers applied to every response. No full CSP yet — Next.js
    # inline scripts make a strict CSP a tuning project of its own (deferred).
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "same-origin"
    }

    # API routes proxied to FastAPI (loopback — all processes share the container).
    handle /api/* {
        reverse_proxy 127.0.0.1:8000
    }

    # All other routes to Next.js (loopback).
    handle {
        reverse_proxy 127.0.0.1:3000
    }
}
