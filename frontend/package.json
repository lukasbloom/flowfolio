{
  "name": "flowfolio-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test --experimental-strip-types \"lib/__tests__/*.test.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:snapshots": "PW_BASE_URL=http://localhost:8081 playwright test --project=snapshots-chromium",
    "test:e2e:screenshots": "PW_BASE_URL=http://localhost:8081 playwright test --project=marketing-chromium",
    "test:e2e:update": "PW_BASE_URL=http://localhost:8081 playwright test --project=snapshots-chromium --update-snapshots",
    "test:e2e:regen-db": "cd .. && docker compose -f compose.yml -f compose.test.yml run --rm -v $PWD/scripts:/app/scripts:ro -v $PWD/tests:/app/tests -e PYTHONPATH=/app flowfolio python scripts/seed-golden.py"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-virtual": "^3.13.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^1.14.0",
    "next": "16.2.x",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.x",
    "js-beautify": "^1.15.4",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  }
}
